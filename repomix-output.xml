                 <svg className="w-5 h-5 md:w-6 md:h-6 mb-1 md:mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 16a5 5 0 116 0 3 3 0 00-6 0zM10 20h4M12 22v-2"></path></svg>
