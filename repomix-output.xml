        { name: '조직도', path: '/company/org' }, 
        { name: '인증 및 파트너', path: '/company/cert' },
        { name: '연혁', path: '/company/history' },
        { name: '오시는 길', path: '/company/location' },
      ]
    },
    {
      title: '비즈니스 모델',
