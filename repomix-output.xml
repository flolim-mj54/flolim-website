          {/* 3. IoT 히어로 카드 결과 화면 */}
          {hasResult && !isAnalyzing && (
            <div className="animate-fade-in relative z-10 w-full max-w-3xl mx-auto">
              
              {/* 타이틀 + 조건 뱃지 */}
