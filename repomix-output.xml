            ))}
          </div>
        </section>

        <BottomNav 
          prev={{ label: '이전 카테고리', title: 'IoT 센서 자동 제어', path: '/smart-building/sensor' }}
          next={{ label: '다음 페이지', title: 'ESG 경영 리포트', path: '/platform/esg' }}
        />
      </div>
    </div>
  );
};

export default PlatformDashboard;
